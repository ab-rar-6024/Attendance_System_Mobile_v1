<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Attendify — Smart Attendance Management System</title>

    <!-- ✅ Google Search Console Verification -->
    <meta name="google-site-verification" content="Q46GCxjLTEK6GwedgNzNoJOyWjdzYSNPVvpDlHIH7Hg" />

    <!-- ✅ SEO Meta Tags -->
    <meta name="description" content="Attendify — Smart Attendance Management System. Track employee attendance, GPS punch-in/out, leave management, and generate monthly reports easily.">
    <meta name="keywords" content="attendance management system, employee attendance tracker, punch in punch out, GPS attendance, leave management, monthly attendance report, Attendify">
    <meta name="author" content="Attendify">
    <meta name="robots" content="index, follow">

    <!-- ✅ Open Graph — preview when shared on WhatsApp, LinkedIn, etc. -->
    <meta property="og:title" content="Attendify — Smart Attendance. Simplified.">
    <meta property="og:description" content="Track employee attendance with GPS punch tracking, PIN-based clock-in, and detailed monthly reports. Built for modern teams.">
    <meta property="og:url" content="https://attendancesystemmobile.vercel.app">
    <meta property="og:type" content="website">
    <meta property="og:image" content="https://attendancesystemmobile.vercel.app/images/logo.png">
    <meta property="og:site_name" content="Attendify">

    <!-- ✅ Twitter Card -->
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="Attendify — Smart Attendance. Simplified.">
    <meta name="twitter:description" content="Track employee attendance with GPS punch tracking and monthly reports.">
    <meta name="twitter:image" content="https://attendancesystemmobile.vercel.app/images/logo.png">

    <!-- ✅ Canonical URL -->
    <link rel="canonical" href="https://attendancesystemmobile.vercel.app">

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg:       #0b0f1a;
            --surface:  #111827;
            --card:     #161d2e;
            --hover:    #1c2540;
            --border:   #1e2d45;
            --gold:     #c9a84c;
            --gold-s:   rgba(201,168,76,0.12);
            --gold-g:   rgba(201,168,76,0.3);
            --txt:      #e8eaf0;
            --muted:    #6b7a99;
            --dim:      #3d4f6e;
            --green:    #22c55e;
            --red:      #ef4444;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: var(--bg);
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
            display: flex;
            overflow: hidden;
        }

        /* ── LEFT PANEL ───────────────────────────── */
        .left-panel {
            flex: 1;
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 48px 52px;
            position: relative;
            overflow: hidden;
        }

        .left-panel::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(var(--border) 1px, transparent 1px),
                linear-gradient(90deg, var(--border) 1px, transparent 1px);
            background-size: 48px 48px;
            opacity: 0.35;
            pointer-events: none;
        }

        .left-panel::after {
            content: '';
            position: absolute;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(201,168,76,0.08) 0%, transparent 65%);
            top: -100px;
            left: -100px;
            pointer-events: none;
        }

        .brand-block {
            position: relative;
            z-index: 1;
            animation: fadeUp 0.6s ease both;
        }

        /* ── LOGO ─────────────────────────────────── */
        .brand-logo {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 44px;
        }

        /*
         * ✅ LOGO IMAGE — points to /images/logo.png in your /public folder
         * Make sure your logo file is saved at: /public/images/logo.png
         */
        .logo-img-wrap {
            width: 68px;
            height: 68px;
            border-radius: 18px;
            background: #ffffff;          /* white bg so logo looks clean */
            border: 1.5px solid var(--gold-g);
            box-shadow: 0 0 28px rgba(201,168,76,0.15);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            flex-shrink: 0;
            padding: 6px;
        }

        .logo-img-wrap img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            display: block;
        }

        .logo-text .name {
            font-family: 'Playfair Display', serif;
            font-size: 26px;
            font-weight: 800;
            color: var(--txt);
            line-height: 1;
            letter-spacing: -0.5px;
        }

        .logo-text .tagline {
            font-size: 10.5px;
            font-weight: 600;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: var(--muted);
            margin-top: 5px;
        }

        .brand-headline {
            font-family: 'Playfair Display', serif;
            font-size: 44px;
            font-weight: 800;
            color: var(--txt);
            line-height: 1.15;
            margin-bottom: 20px;
        }

        .brand-headline em { color: var(--gold); font-style: normal; }

        .brand-desc {
            font-size: 14px;
            color: var(--muted);
            line-height: 1.85;
            max-width: 360px;
        }

        .feature-list {
            display: flex;
            flex-direction: column;
            gap: 14px;
            margin-top: 36px;
            position: relative;
            z-index: 1;
        }

        .feature-item {
            display: flex;
            align-items: center;
            gap: 12px;
            animation: fadeUp 0.6s ease both;
        }

        .feature-item:nth-child(1) { animation-delay: 0.15s; }
        .feature-item:nth-child(2) { animation-delay: 0.25s; }
        .feature-item:nth-child(3) { animation-delay: 0.35s; }

        .feature-dot {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            background: var(--gold-s);
            border: 1px solid var(--gold-g);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
            flex-shrink: 0;
        }

        .feature-text { font-size: 13px; color: var(--muted); font-weight: 500; }

        .left-footer {
            position: relative;
            z-index: 1;
            font-size: 11.5px;
            color: var(--dim);
            animation: fadeUp 0.6s 0.5s ease both;
        }

        /* ── RIGHT PANEL ──────────────────────────── */
        .right-panel {
            width: 480px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 48px;
            background: var(--bg);
        }

        .login-card {
            width: 100%;
            animation: fadeUp 0.5s 0.15s ease both;
        }

        /* Mobile logo */
        .mobile-logo {
            display: none;
            align-items: center;
            gap: 12px;
            margin-bottom: 28px;
        }

        .mobile-logo .logo-img-wrap {
            width: 46px;
            height: 46px;
            border-radius: 12px;
            padding: 4px;
        }

        .mobile-logo .name {
            font-family: 'Playfair Display', serif;
            font-size: 20px;
            font-weight: 800;
            color: var(--txt);
        }

        .mobile-logo .tagline {
            font-size: 9.5px;
            font-weight: 600;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: var(--muted);
            margin-top: 3px;
        }

        /* ── TABS ─────────────────────────────────── */
        .tab-row {
            display: flex;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 4px;
            gap: 4px;
            margin-bottom: 32px;
        }

        .tab-btn {
            flex: 1;
            background: none;
            border: none;
            padding: 9px 0;
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            font-weight: 600;
            color: var(--muted);
            border-radius: 7px;
            cursor: pointer;
            transition: all 0.25s;
        }

        .tab-btn.active { background: var(--gold); color: #0b0f1a; }
        .tab-btn:not(.active):hover { color: var(--txt); background: var(--hover); }

        /* ── FORM HEADER ──────────────────────────── */
        .form-header { margin-bottom: 28px; }

        .form-header .eyebrow {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 8px;
        }

        .form-header h2 {
            font-family: 'Playfair Display', serif;
            font-size: 26px;
            font-weight: 700;
            color: var(--txt);
            margin-bottom: 6px;
        }

        .form-header p { font-size: 13px; color: var(--muted); }

        /* ── FORM BOXES ───────────────────────────── */
        .form-box { display: none; }
        .form-box.active { display: block; }

        /* ── FIELD ────────────────────────────────── */
        .field { margin-bottom: 16px; }

        .field label {
            display: block;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 7px;
        }

        .field input {
            width: 100%;
            background: var(--card);
            border: 1px solid var(--border);
            color: var(--txt);
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            padding: 11px 14px;
            border-radius: 9px;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            /* ✅ Prevents browser autofill highlight (blue/yellow bg) */
            -webkit-box-shadow: 0 0 0px 1000px var(--card) inset !important;
            -webkit-text-fill-color: var(--txt) !important;
        }

        .field input:focus {
            border-color: var(--gold);
            box-shadow: 0 0 0 3px var(--gold-s);
        }

        /* ── SUBMIT ───────────────────────────────── */
        .btn-submit {
            width: 100%;
            background: var(--gold);
            color: #0b0f1a;
            border: none;
            padding: 13px;
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            font-weight: 700;
            border-radius: 9px;
            cursor: pointer;
            margin-top: 8px;
            letter-spacing: 0.3px;
            transition: all 0.2s;
        }

        .btn-submit:hover {
            background: #d4b05a;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(201,168,76,0.3);
        }

        .btn-submit:active { transform: translateY(0); }

        /* ── PIN ──────────────────────────────────── */
        .pin-row {
            display: flex;
            justify-content: center;
            gap: 12px;
            margin-bottom: 26px;
        }

        .pin-row input {
            width: 58px;
            height: 62px;
            background: var(--card);
            border: 1px solid var(--border);
            color: var(--txt);
            font-size: 24px;
            text-align: center;
            border-radius: 12px;
            outline: none;
            font-family: 'DM Sans', sans-serif;
            font-weight: 700;
            transition: border-color 0.2s, box-shadow 0.2s;
            caret-color: var(--gold);
            -webkit-box-shadow: 0 0 0px 1000px var(--card) inset !important;
            -webkit-text-fill-color: var(--txt) !important;
        }

        .pin-row input:focus {
            border-color: var(--gold);
            box-shadow: 0 0 0 3px var(--gold-s);
        }

        /* ── PUNCH BUTTONS ────────────────────────── */
        .punch-btns { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

        .btn-punch {
            padding: 14px;
            border: none;
            font-family: 'DM Sans', sans-serif;
            font-size: 13.5px;
            font-weight: 700;
            border-radius: 9px;
            cursor: pointer;
            letter-spacing: 0.5px;
            transition: all 0.2s;
        }

        .btn-punch:hover { transform: translateY(-1px); }
        .btn-punch:active { transform: translateY(0); }

        .btn-in  { background: rgba(34,197,94,0.15); color: #22c55e; border: 1px solid rgba(34,197,94,0.35); }
        .btn-in:hover  { background: rgba(34,197,94,0.25); box-shadow: 0 4px 16px rgba(34,197,94,0.2); }
        .btn-out { background: rgba(239,68,68,0.12);  color: #ef4444; border: 1px solid rgba(239,68,68,0.3); }
        .btn-out:hover { background: rgba(239,68,68,0.2);  box-shadow: 0 4px 16px rgba(239,68,68,0.2); }

        /* ── FLASH ────────────────────────────────── */
        .flash { font-size: 13px; padding: 10px 14px; border-radius: 8px; margin-bottom: 18px; display: none; }
        .flash.error   { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.25); color: #ef4444; }
        .flash.success { background: rgba(34,197,94,0.1);  border: 1px solid rgba(34,197,94,0.25);  color: #22c55e; }
        .flash.visible { display: block; }

        /* ── ANIMATION ────────────────────────────── */
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ── RESPONSIVE ───────────────────────────── */
        @media (max-width: 900px) {
            .left-panel  { display: none; }
            .right-panel { width: 100%; padding: 32px 24px; }
            .mobile-logo { display: flex; }
        }

        @media (max-width: 480px) {
            .right-panel { padding: 24px 18px; }
            .pin-row input { width: 48px; height: 52px; font-size: 20px; }
        }
    </style>
</head>
<body>

<!-- ════════════ LEFT PANEL ════════════════════════ -->
<div class="left-panel">
    <div class="brand-block">

        <div class="brand-logo">
            <!--
                ✅ LOGO IMAGE
                Your logo file must be saved at: /public/images/logo.png
                If your file is named differently, update the src below.
            -->
            <div class="logo-img-wrap">
                <img src="/images/logo.png" alt="Attendify Logo">
            </div>

            <div class="logo-text">
                <div class="name">ATTENDIFY</div>
                <div class="tagline">Smart Attendance. Simplified.</div>
            </div>
        </div>

        <h1 class="brand-headline">
            Smart tracking.<br>Zero effort.
            <em>Every day.</em>
        </h1>

        <p class="brand-desc">
            Attendify helps modern teams log attendance with precision — real-time punch tracking, GPS location capture, and beautiful monthly reports, all in one place.
        </p>

        <div class="feature-list">
            <div class="feature-item">
                <div class="feature-dot">📍</div>
                <div class="feature-text">GPS-based location tracking on every punch</div>
            </div>
            <div class="feature-item">
                <div class="feature-dot">📊</div>
                <div class="feature-text">Auto-generated monthly attendance reports</div>
            </div>
            <div class="feature-item">
                <div class="feature-dot">🔐</div>
                <div class="feature-text">Secure PIN-based employee punch system</div>
            </div>
        </div>
    </div>

    <div class="left-footer">
        © <%= new Date().getFullYear() %> Attendify. All rights reserved.
    </div>
</div>


<!-- ════════════ RIGHT PANEL ═══════════════════════ -->
<div class="right-panel">
    <div class="login-card">

        <!-- Mobile logo (visible only under 900px) -->
        <div class="mobile-logo">
            <div class="logo-img-wrap">
                <img src="/images/logo.png" alt="Attendify Logo">
            </div>
            <div>
                <div class="name">ATTENDIFY</div>
                <div class="tagline">Smart Attendance. Simplified.</div>
            </div>
        </div>

        <!-- Tabs -->
        <div class="tab-row">
            <button class="tab-btn active" data-target="admin">Admin</button>
            <button class="tab-btn" data-target="employee">Employee</button>
            <button class="tab-btn" data-target="punch">Punch</button>
        </div>

        <!-- Flash message -->
        <div class="flash" id="flashMsg"></div>

        <!-- ── ADMIN ───────────────────────────── -->
        <div id="admin" class="form-box active">
            <div class="form-header">
                <div class="eyebrow">Secure Access</div>
                <h2>Admin Login</h2>
                <p>Sign in to manage your team's attendance</p>
            </div>
            <form method="POST" action="/login" autocomplete="off">
                <input type="hidden" name="role" value="admin">
                <!--
                    ✅ autocomplete="off" on the form stops browser from suggesting saved passwords.
                    The hidden dummy inputs below trick Chrome/Edge into NOT autofilling
                    the real username/password fields.
                -->
                <input type="text"     style="display:none" aria-hidden="true">
                <input type="password" style="display:none" aria-hidden="true">

                <div class="field">
                    <label for="admin_user">Username</label>
                    <input
                        id="admin_user"
                        type="text"
                        name="username"
                        autocomplete="off"
                        autocorrect="off"
                        autocapitalize="off"
                        spellcheck="false"
                        required
                    />
                </div>
                <div class="field">
                    <label for="admin_pass">Password</label>
                    <input
                        id="admin_pass"
                        type="password"
                        name="password"
                        autocomplete="new-password"
                        required
                    />
                </div>
                <button type="submit" class="btn-submit">Sign In as Admin</button>
            </form>
        </div>

        <!-- ── EMPLOYEE ────────────────────────── -->
        <div id="employee" class="form-box">
            <div class="form-header">
                <div class="eyebrow">Employee Portal</div>
                <h2>Employee Login</h2>
                <p>Access your attendance records and leave requests</p>
            </div>
            <form method="POST" action="/login" autocomplete="off">
                <input type="hidden" name="role" value="employee">
                <input type="text"     style="display:none" aria-hidden="true">
                <input type="password" style="display:none" aria-hidden="true">

                <div class="field">
                    <label for="emp_user">Employee Code</label>
                    <input
                        id="emp_user"
                        type="text"
                        name="username"
                        autocomplete="off"
                        autocorrect="off"
                        autocapitalize="off"
                        spellcheck="false"
                        required
                    />
                </div>
                <div class="field">
                    <label for="emp_pass">Password</label>
                    <input
                        id="emp_pass"
                        type="password"
                        name="password"
                        autocomplete="new-password"
                        required
                    />
                </div>
                <button type="submit" class="btn-submit">Sign In as Employee</button>
            </form>
        </div>

        <!-- ── PUNCH ──────────────────────────── -->
        <div id="punch" class="form-box">
            <div class="form-header">
                <div class="eyebrow">Time Clock</div>
                <h2>Employee Punch</h2>
                <p>Enter your 4-digit PIN to record attendance</p>
            </div>

            <div class="pin-row">
                <input type="password" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off">
                <input type="password" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off">
                <input type="password" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off">
                <input type="password" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off">
            </div>

            <div class="punch-btns">
                <button class="btn-punch btn-in"  onclick="doPunch('in')">↑ &nbsp;PUNCH IN</button>
                <button class="btn-punch btn-out" onclick="doPunch('out')">↓ &nbsp;PUNCH OUT</button>
            </div>
        </div>

    </div>
</div>

<script>
    /* ── Tabs ───────────────────────────────────── */
    document.querySelectorAll('.tab-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.tab-btn').forEach(function(b){ b.classList.remove('active'); });
            document.querySelectorAll('.form-box').forEach(function(f){ f.classList.remove('active'); });
            this.classList.add('active');
            document.getElementById(this.dataset.target).classList.add('active');
            hideFlash();
        });
    });

    /* ── Flash ──────────────────────────────────── */
    function showFlash(msg, type) {
        var el = document.getElementById('flashMsg');
        el.textContent = msg;
        el.className = 'flash ' + (type || 'error') + ' visible';
    }
    function hideFlash() {
        document.getElementById('flashMsg').className = 'flash';
    }

    /* ── ✅ Clear autofilled values on page load ── */
    window.addEventListener('DOMContentLoaded', function() {
        /* Small delay to let browser autofill first, then wipe it */
        setTimeout(function() {
            document.querySelectorAll('input[type="text"], input[type="password"]').forEach(function(el) {
                /* Only clear inputs that are NOT inside .pin-row */
                if (!el.closest('.pin-row')) {
                    el.value = '';
                }
            });
        }, 50);
    });

    /* ── PIN inputs ─────────────────────────────── */
    var pinInputs = document.querySelectorAll('.pin-row input');
    pinInputs.forEach(function(input, i) {
        input.addEventListener('input', function() {
            this.value = this.value.replace(/\D/g, '');
            if (this.value && i < pinInputs.length - 1) pinInputs[i + 1].focus();
        });
        input.addEventListener('keydown', function(e) {
            if (e.key === 'Backspace' && !this.value && i > 0) pinInputs[i - 1].focus();
        });
    });

    /* ── Punch ──────────────────────────────────── */
    async function doPunch(type) {
        var pin = Array.from(pinInputs).map(function(d){ return d.value; }).join('');
        if (pin.length !== 4) { showFlash('Please enter your complete 4-digit PIN.', 'error'); return; }

        var btnIn  = document.querySelector('.btn-in');
        var btnOut = document.querySelector('.btn-out');
        btnIn.disabled = btnOut.disabled = true;

        try {
            var res  = await fetch('/punch', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'pin=' + encodeURIComponent(pin) + '&type=' + type
            });
            var data = await res.json();

            if (data.success) {
                var activeBtn = type === 'in' ? btnIn : btnOut;
                var original  = activeBtn.innerHTML;
                activeBtn.innerHTML = '✓ Recorded!';
                showFlash('Punched ' + type.toUpperCase() + ' successfully!', 'success');
                setTimeout(function() {
                    activeBtn.innerHTML = original;
                    pinInputs.forEach(function(p){ p.value = ''; });
                    pinInputs[0].focus();
                    hideFlash();
                }, 2500);
            } else {
                showFlash(data.message || 'Invalid PIN. Please try again.', 'error');
                pinInputs.forEach(function(p){ p.value = ''; });
                pinInputs[0].focus();
            }
        } catch(err) {
            showFlash('Network error. Please check your connection.', 'error');
        } finally {
            btnIn.disabled = btnOut.disabled = false;
        }
    }
</script>

</body>
</html>
