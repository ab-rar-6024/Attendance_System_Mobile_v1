</section>


<!-- ── FAQ ────────────────────────────────────────── -->
<section class="faq-section" id="faq">
    <div class="section-label reveal">Got questions?</div>
    <h2 class="section-title reveal">Frequently asked questions about <em>Attendify</em></h2>
    <p class="section-desc reveal">Everything you need to know about the Attendify attendance management system.</p>

    <div class="faq-list">
        <div class="faq-item reveal">
            <button class="faq-question">
                What is Attendify?
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
                <p>Attendify is a smart attendance management system that helps businesses track employee attendance using GPS punch in/out, secure PIN-based clock-in, leave management, and auto-generated monthly PDF reports. Attendify is designed for small and medium-sized teams.</p>
            </div>
        </div>
        <div class="faq-item reveal">
            <button class="faq-question">
                How does Attendify track attendance?
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
                <p>Employees use a 4-digit PIN to punch in and out on Attendify. Each punch automatically captures the GPS location of the employee. Admins can view all records on a real-time dashboard and generate monthly reports at any time.</p>
            </div>
        </div>
        <div class="faq-item reveal">
            <button class="faq-question">
                Is Attendify free to use?
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
                <p>Yes, Attendify is free to use. Simply visit attendancesystemmobile.vercel.app, log in as Admin, and start adding your team. No credit card or installation is required.</p>
            </div>
        </div>
        <div class="faq-item reveal">
            <button class="faq-question">
                Does Attendify work on mobile phones?
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
                <p>Yes. Attendify is fully responsive and works on all devices — mobile phones, tablets, and desktops. No app download is needed. Just open the Attendify website in any browser.</p>
            </div>
        </div>
        <div class="faq-item reveal">
            <button class="faq-question">
                How do I login to Attendify?
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
                <p>Visit attendancesystemmobile.vercel.app and choose your login type. Admins use username and password. Employees use their employee code and password, or the PIN punch tab with their 4-digit PIN.</p>
            </div>
        </div>
        <div class="faq-item reveal">
            <button class="faq-question">
                Can I generate attendance reports in Attendify?
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
                <p>Yes. Attendify automatically generates detailed monthly attendance reports for every employee. Reports include punch in/out times, GPS location, leave records, and attendance rate — downloadable as PDF.</p>
            </div>
        </div>
    </div>
</section>


<!-- ── FOOTER ─────────────────────────────────────── -->
<footer>
    <div class="footer-logo">
        <img src="/images/logo.png" alt="Attendify">
        <span>ATTENDIFY</span>
    </div>
    <div class="footer-copy">© <%= new Date().getFullYear() %> Attendify. Smart Attendance. Simplified.</div>
</footer>


<script>
    /* ── Tabs ───────────────────────────────────── */
    document.querySelectorAll('.tab-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.tab-btn').forEach(function(b){ b.classList.remove('active'); });
            document.querySelectorAll('.form-box').forEach(function(f){ f.classList.remove('active'); });
            this.classList.add('active');
            document.getElementById(this.dataset.target).classList.add('active');
            hideFlash();
        });
    });

    /* ── Flash ──────────────────────────────────── */
    function showFlash(msg, type) {
        var el = document.getElementById('flashMsg');
        el.textContent = msg;
        el.className = 'flash ' + (type || 'error') + ' visible';
    }
    function hideFlash() { document.getElementById('flashMsg').className = 'flash'; }

    /* ── Clear autofill ─────────────────────────── */
    window.addEventListener('DOMContentLoaded', function() {
        setTimeout(function() {
            document.querySelectorAll('input[type="text"], input[type="password"]').forEach(function(el) {
                if (!el.closest('.pin-row')) el.value = '';
            });
        }, 50);
    });

    /* ── PIN inputs ─────────────────────────────── */
    var pinInputs = document.querySelectorAll('.pin-row input');
    pinInputs.forEach(function(input, i) {
        input.addEventListener('input', function() {
            this.value = this.value.replace(/\D/g, '');
            if (this.value && i < pinInputs.length - 1) pinInputs[i + 1].focus();
        });
        input.addEventListener('keydown', function(e) {
            if (e.key === 'Backspace' && !this.value && i > 0) pinInputs[i - 1].focus();
        });
    });

    /* ── Punch ──────────────────────────────────── */
    async function doPunch(type) {
        var pin = Array.from(pinInputs).map(function(d){ return d.value; }).join('');
        if (pin.length !== 4) { showFlash('Please enter your complete 4-digit PIN.', 'error'); return; }
        var btnIn = document.querySelector('.btn-in');
        var btnOut = document.querySelector('.btn-out');
        btnIn.disabled = btnOut.disabled = true;
        try {
            var res = await fetch('/punch', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'pin=' + encodeURIComponent(pin) + '&type=' + type
            });
            var data = await res.json();
            if (data.success) {
                var activeBtn = type === 'in' ? btnIn : btnOut;
                var original = activeBtn.innerHTML;
                activeBtn.innerHTML = '✓ Recorded!';
                showFlash('Punched ' + type.toUpperCase() + ' successfully!', 'success');
                setTimeout(function() {
                    activeBtn.innerHTML = original;
                    pinInputs.forEach(function(p){ p.value = ''; });
                    pinInputs[0].focus();
                    hideFlash();
                }, 2500);
            } else {
                showFlash(data.message || 'Invalid PIN. Please try again.', 'error');
                pinInputs.forEach(function(p){ p.value = ''; });
                pinInputs[0].focus();
            }
        } catch(err) {
            showFlash('Network error. Please check your connection.', 'error');
        } finally {
            btnIn.disabled = btnOut.disabled = false;
        }
    }

    /* ── FAQ accordion ──────────────────────────── */
    document.querySelectorAll('.faq-question').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var item = this.closest('.faq-item');
            var isOpen = item.classList.contains('open');
            document.querySelectorAll('.faq-item').forEach(function(i){ i.classList.remove('open'); });
            if (!isOpen) item.classList.add('open');
        });
    });

    /* ── Scroll reveal ──────────────────────────── */
    var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(function(el) { observer.observe(el); });
</script>

</body>
</html>
