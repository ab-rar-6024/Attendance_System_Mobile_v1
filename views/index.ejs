<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Attendify — Smart Attendance Management System</title>

    <!-- ✅ Google Search Console Verification -->
    <meta name="google-site-verification" content="Q46GCxjLTEK6GwedgNzNoJOyWjdzYSNPVvpDlHIH7Hg" />

    <!-- ✅ SEO -->
    <meta name="description" content="Attendify — Smart Attendance Management System. Track employee attendance with GPS punch-in/out, PIN-based clock, leave management, and monthly reports.">
    <meta name="keywords" content="attendance management system, employee attendance tracker, punch in punch out, GPS attendance, leave management, monthly attendance report, Attendify">
    <meta name="author" content="Attendify">
    <meta name="robots" content="index, follow">

    <!-- ✅ Open Graph -->
    <meta property="og:title" content="Attendify — Smart Attendance. Simplified.">
    <meta property="og:description" content="Track employee attendance with GPS punch tracking, PIN-based clock-in, and detailed monthly reports. Built for modern teams.">
    <meta property="og:url" content="https://attendancesystemmobile.vercel.app">
    <meta property="og:type" content="website">
    <meta property="og:image" content="https://attendancesystemmobile.vercel.app/images/logo.png">
    <meta property="og:site_name" content="Attendify">

    <!-- ✅ Twitter -->
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="Attendify — Smart Attendance. Simplified.">
    <meta name="twitter:description" content="Track employee attendance with GPS punch tracking and monthly reports.">
    <meta name="twitter:image" content="https://attendancesystemmobile.vercel.app/images/logo.png">

    <!-- ✅ Canonical -->
    <link rel="canonical" href="https://attendancesystemmobile.vercel.app">

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800;900&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg:      #0b0f1a;
            --surface: #111827;
            --card:    #161d2e;
            --hover:   #1c2540;
            --border:  #1e2d45;
            --gold:    #c9a84c;
            --gold-s:  rgba(201,168,76,0.12);
            --gold-g:  rgba(201,168,76,0.28);
            --gold-b:  rgba(201,168,76,0.06);
            --txt:     #e8eaf0;
            --muted:   #6b7a99;
            --dim:     #3d4f6e;
            --green:   #22c55e;
            --red:     #ef4444;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        html { scroll-behavior: smooth; }

        body {
            background: var(--bg);
            font-family: 'DM Sans', sans-serif;
            color: var(--txt);
            overflow-x: hidden;
        }

        /* ══════════════════════════════════════════
           NAVBAR
        ══════════════════════════════════════════ */
        .nav {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 48px;
            height: 68px;
            background: rgba(11,15,26,0.85);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border);
        }

        .nav-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .nav-logo-img {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: #fff;
            border: 1px solid var(--gold-g);
            padding: 3px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .nav-logo-img img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .nav-logo-text {
            font-family: 'Playfair Display', serif;
            font-size: 18px;
            font-weight: 800;
            color: var(--txt);
            letter-spacing: -0.3px;
        }

        .nav-links {
            display: flex;
            gap: 32px;
            list-style: none;
        }

        .nav-links a {
            font-size: 13.5px;
            font-weight: 500;
            color: var(--muted);
            text-decoration: none;
            transition: color 0.2s;
        }

        .nav-links a:hover { color: var(--txt); }

        .nav-cta {
            background: var(--gold);
            color: #0b0f1a;
            border: none;
            padding: 9px 22px;
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            font-weight: 700;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
        }

        .nav-cta:hover { background: #d4b05a; transform: translateY(-1px); }

        /* ══════════════════════════════════════════
           HERO
        ══════════════════════════════════════════ */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 100px 48px 80px;
            position: relative;
            overflow: hidden;
            gap: 60px;
        }

        /* Grid texture */
        .hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(var(--border) 1px, transparent 1px),
                linear-gradient(90deg, var(--border) 1px, transparent 1px);
            background-size: 52px 52px;
            opacity: 0.3;
            pointer-events: none;
        }

        /* Gold glow top-left */
        .hero::after {
            content: '';
            position: absolute;
            width: 700px;
            height: 700px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(201,168,76,0.08) 0%, transparent 65%);
            top: -200px;
            left: -200px;
            pointer-events: none;
        }

        /* Second glow bottom-right */
        .hero-glow2 {
            position: absolute;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(59,126,248,0.06) 0%, transparent 65%);
            bottom: -100px;
            right: -100px;
            pointer-events: none;
        }

        .hero-left {
            flex: 1;
            position: relative;
            z-index: 1;
            max-width: 580px;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--gold-s);
            border: 1px solid var(--gold-g);
            border-radius: 100px;
            padding: 6px 14px;
            font-size: 11.5px;
            font-weight: 600;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 28px;
            animation: fadeUp 0.5s ease both;
        }

        .hero-badge span { width: 6px; height: 6px; border-radius: 50%; background: var(--gold); display: block; }

        .hero-title {
            font-family: 'Playfair Display', serif;
            font-size: 62px;
            font-weight: 900;
            line-height: 1.08;
            color: var(--txt);
            margin-bottom: 24px;
            animation: fadeUp 0.5s 0.1s ease both;
        }

        .hero-title em { color: var(--gold); font-style: normal; }

        .hero-title .line2 {
            display: block;
            font-style: italic;
            color: var(--muted);
            font-size: 54px;
        }

        .hero-desc {
            font-size: 16px;
            color: var(--muted);
            line-height: 1.85;
            max-width: 460px;
            margin-bottom: 40px;
            animation: fadeUp 0.5s 0.2s ease both;
        }

        .hero-actions {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
            animation: fadeUp 0.5s 0.3s ease both;
        }

        .btn-primary {
            background: var(--gold);
            color: #0b0f1a;
            border: none;
            padding: 14px 32px;
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            font-weight: 700;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-block;
        }

        .btn-primary:hover { background: #d4b05a; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(201,168,76,0.3); }

        .btn-ghost {
            background: transparent;
            color: var(--txt);
            border: 1px solid var(--border);
            padding: 14px 32px;
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            font-weight: 600;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-block;
        }

        .btn-ghost:hover { border-color: var(--gold-g); background: var(--gold-s); }

        .hero-stats {
            display: flex;
            gap: 36px;
            margin-top: 48px;
            animation: fadeUp 0.5s 0.4s ease both;
        }

        .stat-item .val {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            font-weight: 800;
            color: var(--gold);
        }

        .stat-item .lbl {
            font-size: 12px;
            color: var(--muted);
            margin-top: 3px;
            font-weight: 500;
        }

        /* ── RIGHT: LOGIN FORM ───────────────────── */
        .hero-right {
            width: 420px;
            flex-shrink: 0;
            position: relative;
            z-index: 1;
            animation: fadeUp 0.5s 0.2s ease both;
        }

        .login-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 32px;
            box-shadow: 0 24px 60px rgba(0,0,0,0.4), 0 0 0 1px rgba(201,168,76,0.05);
        }

        .login-card-header {
            text-align: center;
            margin-bottom: 24px;
        }

        .login-card-header .logo-wrap {
            width: 56px;
            height: 56px;
            border-radius: 14px;
            background: #fff;
            border: 1.5px solid var(--gold-g);
            margin: 0 auto 14px;
            padding: 5px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            box-shadow: 0 0 24px rgba(201,168,76,0.15);
        }

        .login-card-header .logo-wrap img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .login-card-header h3 {
            font-family: 'Playfair Display', serif;
            font-size: 20px;
            font-weight: 700;
            color: var(--txt);
            margin-bottom: 4px;
        }

        .login-card-header p {
            font-size: 12.5px;
            color: var(--muted);
        }

        /* Tabs */
        .tab-row {
            display: flex;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 4px;
            gap: 4px;
            margin-bottom: 24px;
        }

        .tab-btn {
            flex: 1;
            background: none;
            border: none;
            padding: 8px 0;
            font-family: 'DM Sans', sans-serif;
            font-size: 12.5px;
            font-weight: 600;
            color: var(--muted);
            border-radius: 7px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .tab-btn.active { background: var(--gold); color: #0b0f1a; }
        .tab-btn:not(.active):hover { color: var(--txt); background: var(--hover); }

        /* Form */
        .form-box { display: none; }
        .form-box.active { display: block; }

        .form-header { margin-bottom: 20px; }

        .form-header .eyebrow {
            font-size: 9.5px;
            font-weight: 600;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 6px;
        }

        .form-header h4 {
            font-family: 'Playfair Display', serif;
            font-size: 20px;
            font-weight: 700;
            color: var(--txt);
            margin-bottom: 4px;
        }

        .form-header p { font-size: 12px; color: var(--muted); }

        .field { margin-bottom: 14px; }

        .field label {
            display: block;
            font-size: 10.5px;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 6px;
        }

        .field input {
            width: 100%;
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--txt);
            font-family: 'DM Sans', sans-serif;
            font-size: 13.5px;
            padding: 10px 13px;
            border-radius: 8px;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            -webkit-box-shadow: 0 0 0px 1000px var(--surface) inset !important;
            -webkit-text-fill-color: var(--txt) !important;
        }

        .field input:focus {
            border-color: var(--gold);
            box-shadow: 0 0 0 3px var(--gold-s);
        }

        .btn-submit {
            width: 100%;
            background: var(--gold);
            color: #0b0f1a;
            border: none;
            padding: 12px;
            font-family: 'DM Sans', sans-serif;
            font-size: 13.5px;
            font-weight: 700;
            border-radius: 8px;
            cursor: pointer;
            margin-top: 6px;
            letter-spacing: 0.3px;
            transition: all 0.2s;
        }

        .btn-submit:hover { background: #d4b05a; transform: translateY(-1px); box-shadow: 0 4px 14px rgba(201,168,76,0.3); }
        .btn-submit:active { transform: translateY(0); }

        /* PIN */
        .pin-row {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 20px;
        }

        .pin-row input {
            width: 52px;
            height: 56px;
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--txt);
            font-size: 22px;
            text-align: center;
            border-radius: 10px;
            outline: none;
            font-family: 'DM Sans', sans-serif;
            font-weight: 700;
            transition: border-color 0.2s, box-shadow 0.2s;
            -webkit-box-shadow: 0 0 0px 1000px var(--surface) inset !important;
            -webkit-text-fill-color: var(--txt) !important;
        }

        .pin-row input:focus { border-color: var(--gold); box-shadow: 0 0 0 3px var(--gold-s); }

        .punch-btns { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

        .btn-punch {
            padding: 12px;
            border: none;
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            font-weight: 700;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-punch:hover { transform: translateY(-1px); }

        .btn-in  { background: rgba(34,197,94,0.15); color: #22c55e; border: 1px solid rgba(34,197,94,0.35); }
        .btn-in:hover  { background: rgba(34,197,94,0.25); }
        .btn-out { background: rgba(239,68,68,0.12);  color: #ef4444; border: 1px solid rgba(239,68,68,0.3); }
        .btn-out:hover { background: rgba(239,68,68,0.2); }

        /* Flash */
        .flash { font-size: 12.5px; padding: 9px 13px; border-radius: 8px; margin-bottom: 16px; display: none; }
        .flash.error   { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.25); color: #ef4444; }
        .flash.success { background: rgba(34,197,94,0.1);  border: 1px solid rgba(34,197,94,0.25);  color: #22c55e; }
        .flash.visible { display: block; }

        /* ══════════════════════════════════════════
           FEATURES SECTION
        ══════════════════════════════════════════ */
        .section {
            padding: 100px 48px;
            position: relative;
        }

        .section-label {
            font-size: 10.5px;
            font-weight: 600;
            letter-spacing: 3.5px;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 16px;
            text-align: center;
        }

        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: 40px;
            font-weight: 800;
            color: var(--txt);
            text-align: center;
            line-height: 1.2;
            max-width: 560px;
            margin: 0 auto 16px;
        }

        .section-title em { color: var(--gold); font-style: normal; }

        .section-desc {
            font-size: 14.5px;
            color: var(--muted);
            text-align: center;
            max-width: 480px;
            margin: 0 auto 64px;
            line-height: 1.8;
        }

        /* Feature grid */
        .features-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            max-width: 1100px;
            margin: 0 auto;
        }

        .feature-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 28px;
            transition: all 0.25s;
            position: relative;
            overflow: hidden;
        }

        .feature-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .feature-card:hover { border-color: var(--gold-g); transform: translateY(-3px); box-shadow: 0 12px 32px rgba(0,0,0,0.3); }
        .feature-card:hover::before { opacity: 1; }

        .feature-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: var(--gold-s);
            border: 1px solid var(--gold-g);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            margin-bottom: 18px;
        }

        .feature-card h3 {
            font-family: 'Playfair Display', serif;
            font-size: 17px;
            font-weight: 700;
            color: var(--txt);
            margin-bottom: 10px;
        }

        .feature-card p {
            font-size: 13.5px;
            color: var(--muted);
            line-height: 1.75;
        }

        /* ══════════════════════════════════════════
           HOW IT WORKS
        ══════════════════════════════════════════ */
        .steps-section {
            padding: 100px 48px;
            background: var(--surface);
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
        }

        .steps-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 24px;
            max-width: 1100px;
            margin: 0 auto;
        }

        .step-card {
            text-align: center;
            padding: 24px 16px;
        }

        .step-num {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            border: 1.5px solid var(--gold-g);
            background: var(--gold-s);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Playfair Display', serif;
            font-size: 20px;
            font-weight: 800;
            color: var(--gold);
            margin: 0 auto 18px;
        }

        .step-card h4 {
            font-family: 'Playfair Display', serif;
            font-size: 16px;
            font-weight: 700;
            color: var(--txt);
            margin-bottom: 8px;
        }

        .step-card p { font-size: 13px; color: var(--muted); line-height: 1.7; }

        /* ══════════════════════════════════════════
           FOOTER
        ══════════════════════════════════════════ */
        footer {
            padding: 32px 48px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-top: 1px solid var(--border);
        }

        .footer-logo {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .footer-logo img {
            width: 30px;
            height: 30px;
            border-radius: 8px;
            background: #fff;
            padding: 2px;
            object-fit: contain;
        }

        .footer-logo span {
            font-family: 'Playfair Display', serif;
            font-size: 16px;
            font-weight: 700;
            color: var(--txt);
        }

        .footer-copy { font-size: 12px; color: var(--dim); }

        /* ══════════════════════════════════════════
           ANIMATIONS
        ══════════════════════════════════════════ */
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .reveal {
            opacity: 0;
            transform: translateY(24px);
            transition: opacity 0.6s ease, transform 0.6s ease;
        }

        .reveal.visible { opacity: 1; transform: translateY(0); }

        /* ══════════════════════════════════════════
           RESPONSIVE
        ══════════════════════════════════════════ */
        @media (max-width: 1024px) {
            .hero { flex-direction: column; padding: 100px 32px 60px; align-items: flex-start; }
            .hero-right { width: 100%; max-width: 480px; }
            .hero-title { font-size: 48px; }
            .hero-title .line2 { font-size: 40px; }
            .features-grid { grid-template-columns: repeat(2, 1fr); }
            .steps-grid { grid-template-columns: repeat(2, 1fr); }
        }

        @media (max-width: 768px) {
            .nav { padding: 0 20px; }
            .nav-links { display: none; }
            .hero { padding: 90px 20px 50px; gap: 40px; }
            .hero-title { font-size: 38px; }
            .hero-title .line2 { font-size: 32px; }
            .section { padding: 70px 20px; }
            .features-grid { grid-template-columns: 1fr; }
            .steps-section { padding: 70px 20px; }
            .steps-grid { grid-template-columns: 1fr 1fr; }
            footer { flex-direction: column; gap: 12px; text-align: center; padding: 24px 20px; }
            .hero-stats { gap: 24px; }
        }

        @media (max-width: 480px) {
            .hero-title { font-size: 32px; }
            .hero-title .line2 { font-size: 28px; }
            .steps-grid { grid-template-columns: 1fr; }
            .pin-row input { width: 46px; height: 50px; font-size: 20px; }
        }
    </style>
</head>
<body>

<!-- ══════════════════════════════════════════════
     NAVBAR
══════════════════════════════════════════════ -->
<nav class="nav">
    <a href="/" class="nav-logo">
        <div class="nav-logo-img">
            <img src="/images/logo.png" alt="Attendify">
        </div>
        <span class="nav-logo-text">ATTENDIFY</span>
    </a>

    <ul class="nav-links">
        <li><a href="#features">Features</a></li>
        <li><a href="#how-it-works">How it works</a></li>
        <li><a href="#login">Login</a></li>
    </ul>

    <a href="#login" class="nav-cta">Get Started</a>
</nav>


<!-- ══════════════════════════════════════════════
     HERO + LOGIN
══════════════════════════════════════════════ -->
<section class="hero" id="login">
    <div class="hero-glow2"></div>

    <!-- Left: Headline -->
    <div class="hero-left">
        <div class="hero-badge">
            <span></span> Smart Attendance System
        </div>

        <h1 class="hero-title">
            Track every<br>
            <em>punch.</em>
            <span class="line2">Effortlessly.</span>
        </h1>

        <p class="hero-desc">
            Attendify gives your team a powerful attendance platform — GPS-based punch tracking, PIN clock-in, leave management, and detailed monthly reports. All in one place.
        </p>

        <div class="hero-actions">
            <a href="#login" class="btn-primary">Login Now</a>
