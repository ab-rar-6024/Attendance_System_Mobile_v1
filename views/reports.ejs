<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reports — Smart Attendance</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <!-- ✅ FIXED: Full Chart.js path with /dist/chart.umd.min.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>

    <style>
        :root {
            --bg:      #0b0f1a;
            --surface: #111827;
            --card:    #161d2e;
            --hover:   #1c2540;
            --border:  #1e2d45;
            --gold:    #c9a84c;
            --gold-s:  rgba(201,168,76,0.12);
            --gold-g:  rgba(201,168,76,0.25);
            --txt:     #e8eaf0;
            --muted:   #6b7a99;
            --dim:     #3d4f6e;
            --blue:    #3b7ef8;
            --green:   #22c55e;
            --red:     #ef4444;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: var(--bg);
            color: var(--txt);
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            min-height: 100vh;
        }

        .wrap { max-width: 1300px; margin: 0 auto; padding: 36px 24px; }

        /* ── Page Header ─────────────────────────── */
        .pg-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
            margin-bottom: 32px;
        }

        .eyebrow {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 6px;
        }

        .pg-header h1 {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            font-weight: 700;
            color: var(--txt);
        }

        .pg-header p {
            font-size: 13.5px;
            color: var(--muted);
            margin-top: 4px;
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--card);
            border: 1px solid var(--border);
            color: var(--muted);
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            font-weight: 500;
            padding: 9px 18px;
            border-radius: 8px;
            text-decoration: none;
            transition: all 0.2s;
            white-space: nowrap;
        }
        .btn-back:hover { border-color: var(--gold); color: var(--gold); }

        /* ── Stat Cards ──────────────────────────── */
        .stats {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 28px;
        }

        .s-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 18px 20px;
            position: relative;
            overflow: hidden;
            transition: border-color 0.2s, transform 0.2s;
        }
        .s-card:hover { border-color: var(--gold); transform: translateY(-2px); }
        .s-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 2px;
        }
        .s-card.c-gold::before { background: var(--gold); }
        .s-card.c-blue::before { background: var(--blue); }
        .s-card.c-grn::before  { background: var(--green); }
        .s-card.c-red::before  { background: var(--red); }

        .s-lbl {
            font-size: 10.5px;
            font-weight: 600;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 8px;
        }
        .s-val {
            font-family: 'Playfair Display', serif;
            font-size: 30px;
            font-weight: 700;
            line-height: 1;
            color: var(--txt);
        }
        .s-sub { font-size: 11.5px; color: var(--muted); margin-top: 6px; }

        /* ── Chart Cards ─────────────────────────── */
        .chart-grid {
            display: grid;
            grid-template-columns: 3fr 2fr;
            gap: 20px;
            margin-bottom: 28px;
        }

        .c-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 22px 24px;
            transition: border-color 0.2s;
        }
        .c-card:hover { border-color: var(--border); }

        .c-head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 20px;
        }

        .c-title {
            font-family: 'Playfair Display', serif;
            font-size: 15px;
            font-weight: 700;
            color: var(--txt);
        }
        .c-sub { font-size: 11.5px; color: var(--muted); margin-top: 3px; }

        .c-badge {
            font-size: 10.5px;
            font-weight: 600;
            background: var(--gold-s);
            color: var(--gold);
            border: 1px solid var(--gold-g);
            padding: 3px 10px;
            border-radius: 20px;
            white-space: nowrap;
        }

        /* ✅ KEY: fixed px height so Chart.js renders correctly */
        .bar-wrap {
            position: relative;
            width: 100%;
            height: 220px;
        }

        .donut-wrap {
            position: relative;
            width: 100%;
            height: 220px;
        }

        /* Donut center label */
        .donut-center {
            position: absolute;
            top: 42%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
            pointer-events: none;
        }
        .donut-center .big {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            font-weight: 700;
            line-height: 1;
            color: var(--txt);
        }
        .donut-center .small {
            font-size: 11px;
            color: var(--muted);
            margin-top: 4px;
        }

        /* ── Second Row Charts ───────────────────── */
        .chart-grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 28px;
        }

        /* ── Legend Pills ────────────────────────── */
        .legend-row {
            display: flex;
            gap: 16px;
            margin-top: 12px;
            flex-wrap: wrap;
        }
        .legend-pill {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: var(--muted);
        }
        .legend-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        /* ── Summary Table ───────────────────────── */
        .t-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
        }

        .t-head-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 20px;
            border-bottom: 1px solid var(--border);
        }

        .t-title {
            font-family: 'Playfair Display', serif;
            font-size: 15px;
            font-weight: 700;
        }

        .t-card table { width: 100%; border-collapse: collapse; }
        .t-card thead th {
            background: var(--hover);
            color: var(--muted);
            font-size: 10.5px;
            font-weight: 600;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            padding: 11px 16px;
            border-bottom: 1px solid var(--border);
            text-align: center;
            white-space: nowrap;
        }
        .t-card tbody td {
            padding: 10px 16px;
            border-bottom: 1px solid var(--border);
            font-size: 13px;
            text-align: center;
            vertical-align: middle;
        }
        .t-card tbody tr:last-child td { border-bottom: none; }
        .t-card tbody tr:hover td { background: var(--hover); }

        .bp { background: rgba(34,197,94,.12); color: #22c55e; border: 1px solid rgba(34,197,94,.25); font-size: 10.5px; font-weight: 600; padding: 2px 9px; border-radius: 20px; }
        .ba { background: rgba(239,68,68,.12); color: #ef4444; border: 1px solid rgba(239,68,68,.25); font-size: 10.5px; font-weight: 600; padding: 2px 9px; border-radius: 20px; }

        /* ── Divider ─────────────────────────────── */
        .sec-title { font-family: 'Playfair Display', serif; font-size: 16px; font-weight: 700; margin-bottom: 4px; }
        .sec-line  { width: 32px; height: 2px; background: var(--gold); border-radius: 2px; margin-bottom: 16px; }

        /* ── Footer ──────────────────────────────── */
        .page-footer {
            margin-top: 32px;
            text-align: center;
            font-size: 12px;
            color: var(--dim);
            border-top: 1px solid var(--border);
            padding-top: 20px;
        }
        .page-footer em { color: var(--gold); font-style: normal; }

        /* ── Scrollbar ───────────────────────────── */
        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-track { background: var(--bg); }
        ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--gold); }

        /* ── Responsive ──────────────────────────── */
        @media (max-width: 1024px) {
            .chart-grid   { grid-template-columns: 1fr; }
            .chart-grid-2 { grid-template-columns: 1fr; }
            .stats        { grid-template-columns: repeat(2, 1fr); }
        }
        @media (max-width: 600px) {
            .stats   { grid-template-columns: repeat(2, 1fr); gap: 10px; }
            .wrap    { padding: 20px 14px; }
            .s-val   { font-size: 22px; }
            .hide-sm { display: none; }
        }
    </style>
</head>
<body>

<%
/* ── Compute summary stats safely ── */
const _present = typeof present !== 'undefined' ? present : 0;
const _absent  = typeof absent  !== 'undefined' ? absent  : 0;
const _total   = _present + _absent;
const _rate    = _total > 0 ? Math.round(_present / _total * 100) : 0;

const _labels = typeof labels !== 'undefined' ? labels : [];
const _counts = typeof counts !== 'undefined' ? counts : [];
const _weekTotal = _counts.reduce(function(a,b){ return a+b; }, 0);
const _weekPeak  = _counts.length > 0 ? Math.max.apply(null, _counts) : 0;
%>

<div class="wrap">

    <!-- Header -->
    <div class="pg-header">
        <div>
            <div class="eyebrow">Smart Attendance System</div>
            <h1>Attendance Reports</h1>
            <p>Live statistics and attendance analytics</p>
        </div>
        <a href="/admin" class="btn-back">← Back to Dashboard</a>
    </div>

    <!-- Stat Cards -->
    <div class="stats">
        <div class="s-card c-gold">
            <div class="s-lbl">Total Today</div>
            <div class="s-val"><%= _total %></div>
            <div class="s-sub">All employees</div>
        </div>
        <div class="s-card c-grn">
            <div class="s-lbl">Present</div>
            <div class="s-val"><%= _present %></div>
            <div class="s-sub">Punched in today</div>
        </div>
        <div class="s-card c-red">
            <div class="s-lbl">Absent</div>
            <div class="s-val"><%= _absent %></div>
            <div class="s-sub">Marked absent</div>
        </div>
        <div class="s-card c-blue">
            <div class="s-lbl">Attendance Rate</div>
            <div class="s-val"><%= _rate %>%</div>
            <div class="s-sub">Today's rate</div>
        </div>
    </div>

    <!-- Main Charts Row -->
    <div class="chart-grid">

        <!-- Bar Chart: Last 7 Days -->
        <div class="c-card">
            <div class="c-head">
                <div>
                    <div class="c-title">Last 7 Days Punch-In Activity</div>
                    <div class="c-sub">Daily check-ins over the past week</div>
                </div>
                <span class="c-badge">Weekly View</span>
            </div>
            <!-- ✅ Fixed height wrapper — Chart.js REQUIRES this -->
            <div class="bar-wrap">
                <canvas id="barChart"></canvas>
            </div>
            <div class="legend-row">
                <div class="legend-pill">
                    <div class="legend-dot" style="background:#c9a84c;"></div>
                    Weekly Total: <strong style="color:var(--txt);margin-left:2px;"><%= _weekTotal %></strong>
                </div>
                <div class="legend-pill">
                    <div class="legend-dot" style="background:#3b7ef8;"></div>
                    Peak Day: <strong style="color:var(--txt);margin-left:2px;"><%= _weekPeak %></strong>
                </div>
            </div>
        </div>

        <!-- Donut Chart: Present vs Absent -->
        <div class="c-card">
            <div class="c-head">
                <div>
                    <div class="c-title">Present vs Absent</div>
                    <div class="c-sub">Today's attendance breakdown</div>
                </div>
            </div>
            <div class="donut-wrap">
                <canvas id="donutChart"></canvas>
                <div class="donut-center">
                    <div class="big"><%= _rate %>%</div>
                    <div class="small">Present Rate</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Second Row: Extra Visual Summaries -->
    <div class="chart-grid-2">

        <!-- Weekly Trend Line Chart -->
        <div class="c-card">
            <div class="c-head">
                <div>
                    <div class="c-title">Weekly Trend</div>
                    <div class="c-sub">Punch-in trend over last 7 days</div>
                </div>
                <span class="c-badge">Line View</span>
            </div>
            <div class="bar-wrap">
                <canvas id="lineChart"></canvas>
            </div>
        </div>

        <!-- Today's Summary Bar -->
        <div class="c-card">
            <div class="c-head">
                <div>
                    <div class="c-title">Today at a Glance</div>
                    <div class="c-sub">Present, Absent comparison</div>
                </div>
            </div>
            <div class="bar-wrap">
                <canvas id="todayChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Summary Table -->
    <div class="sec-title">Weekly Summary</div>
    <div class="sec-line"></div>

    <div class="t-card">
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Punch-ins</th>
                    <th>Trend</th>
                </tr>
            </thead>
            <tbody>
                <% for (let i = 0; i < _labels.length; i++) { %>
                <tr>
                    <td style="font-weight:600;text-align:left;padding-left:20px;"><%= _labels[i] %></td>
                    <td>
                        <span class="<%= _counts[i] > 0 ? 'bp' : 'ba' %>">
                            <%= _counts[i] %> check-in<%= _counts[i] !== 1 ? 's' : '' %>
                        </span>
                    </td>
                    <td>
                        <div style="display:flex;align-items:center;justify-content:center;gap:8px;">
                            <div style="background:var(--hover);border-radius:4px;height:6px;width:120px;overflow:hidden;">
                                <div style="background:var(--gold);height:100%;width:<%= _weekPeak > 0 ? Math.round(_counts[i]/_weekPeak*100) : 0 %>%;border-radius:4px;transition:width 0.8s;"></div>
                            </div>
                            <span style="font-size:11px;color:var(--muted);min-width:28px;"><%= _weekPeak > 0 ? Math.round(_counts[i]/_weekPeak*100) : 0 %>%</span>
                        </div>
                    </td>
                </tr>
                <% } %>
                <% if (_labels.length === 0) { %>
                <tr><td colspan="3" style="text-align:center;color:var(--dim);padding:28px;">No data available</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <div class="page-footer">
        Generated on <%= new Date().toLocaleString() %> &nbsp;|&nbsp; <em>Smart Attendance System</em>
    </div>
</div>

<!-- ✅ All charts initialized after DOM is ready, data injected server-side -->
<script>
(function() {

    var barLabels    = <%- JSON.stringify(_labels) %>;
    var barData      = <%- JSON.stringify(_counts) %>;
    var presentCount = <%- _present %>;
    var absentCount  = <%- _absent %>;

    var GOLD   = '#c9a84c';
    var GOLD_A = 'rgba(201,168,76,0.3)';
    var GOLD_H = 'rgba(201,168,76,0.55)';
    var GREEN  = 'rgba(34,197,94,0.75)';
    var RED    = 'rgba(239,68,68,0.75)';
    var BLUE   = '#3b7ef8';
    var BLUE_A = 'rgba(59,126,248,0.15)';
    var MUTED  = '#6b7a99';
    var BORDER = '#1e2d45';
    var CARD   = '#161d2e';

    var tooltipBase = {
        backgroundColor: CARD,
        borderColor: BORDER,
        borderWidth: 1,
        titleColor: GOLD,
        bodyColor: '#e8eaf0',
        padding: 12
    };

    var xAxis = {
        ticks: { color: MUTED, font: { size: 11 } },
        grid:  { display: false },
        border:{ color: BORDER }
    };

    var yAxis = {
        beginAtZero: true,
        ticks: { color: MUTED, font: { size: 11 }, stepSize: 1 },
        grid:  { color: 'rgba(30,45,69,0.9)' },
        border:{ color: BORDER }
    };

    /* ── 1. Bar Chart: Last 7 Days ──────────────── */
    var barEl = document.getElementById('barChart');
    if (barEl) {
        if (barLabels.length > 0) {
            new Chart(barEl, {
                type: 'bar',
                data: {
                    labels: barLabels,
                    datasets: [{
                        label: 'Punch-ins',
                        data: barData,
                        backgroundColor: GOLD_A,
                        borderColor: GOLD,
                        borderWidth: 2,
                        borderRadius: 6,
                        borderSkipped: false,
                        hoverBackgroundColor: GOLD_H
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    animation: { duration: 700 },
                    scales: { x: xAxis, y: yAxis },
                    plugins: {
                        legend: { display: false },
                        tooltip: Object.assign({}, tooltipBase, {
                            callbacks: {
                                label: function(c) { return '  ' + c.parsed.y + ' punch-in' + (c.parsed.y !== 1 ? 's' : ''); }
                            }
                        })
                    }
                }
            });
        } else {
            barEl.parentElement.innerHTML =
                '<div style="height:220px;display:flex;align-items:center;justify-content:center;color:#3d4f6e;font-size:13px;">No data for last 7 days</div>';
        }
    }

    /* ── 2. Donut Chart: Present vs Absent ──────── */
    var donutEl = document.getElementById('donutChart');
    if (donutEl) {
        new Chart(donutEl, {
            type: 'doughnut',
            data: {
                labels: ['Present', 'Absent'],
                datasets: [{
                    data: [presentCount, absentCount],
                    backgroundColor: [GREEN, RED],
                    borderColor: ['rgba(34,197,94,1)', 'rgba(239,68,68,1)'],
                    borderWidth: 2,
                    hoverOffset: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '72%',
                animation: { duration: 800 },
                plugins: {
                    legend: {
                        display: true,
                        position: 'bottom',
                        labels: { color: MUTED, font: { size: 12 }, padding: 16, usePointStyle: true, pointStyleWidth: 8 }
                    },
                    tooltip: Object.assign({}, tooltipBase, {
                        callbacks: {
                            label: function(c) { return '  ' + c.label + ': ' + c.parsed + ' employee' + (c.parsed !== 1 ? 's' : ''); }
                        }
                    })
                }
            }
        });
    }

    /* ── 3. Line Chart: Weekly Trend ────────────── */
    var lineEl = document.getElementById('lineChart');
    if (lineEl) {
        if (barLabels.length > 0) {
            new Chart(lineEl, {
                type: 'line',
                data: {
                    labels: barLabels,
                    datasets: [{
                        label: 'Punch-ins',
                        data: barData,
                        borderColor: BLUE,
                        backgroundColor: BLUE_A,
                        borderWidth: 2.5,
                        pointBackgroundColor: BLUE,
                        pointBorderColor: CARD,
                        pointBorderWidth: 2,
                        pointRadius: 5,
                        pointHoverRadius: 7,
                        tension: 0.4,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    animation: { duration: 900 },
                    scales: { x: xAxis, y: yAxis },
                    plugins: {
                        legend: { display: false },
                        tooltip: Object.assign({}, tooltipBase, {
                            callbacks: {
                                label: function(c) { return '  ' + c.parsed.y + ' check-in' + (c.parsed.y !== 1 ? 's' : ''); }
                            }
                        })
                    }
                }
            });
        } else {
            lineEl.parentElement.innerHTML =
                '<div style="height:220px;display:flex;align-items:center;justify-content:center;color:#3d4f6e;font-size:13px;">No data available</div>';
        }
    }

    /* ── 4. Today's Horizontal Bar ──────────────── */
    var todayEl = document.getElementById('todayChart');
    if (todayEl) {
        new Chart(todayEl, {
            type: 'bar',
            data: {
                labels: ['Present', 'Absent'],
                datasets: [{
                    data: [presentCount, absentCount],
                    backgroundColor: [GREEN, RED],
                    borderColor: ['rgba(34,197,94,1)', 'rgba(239,68,68,1)'],
                    borderWidth: 2,
                    borderRadius: 6,
                    borderSkipped: false
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                animation: { duration: 700 },
                scales: {
                    x: Object.assign({}, yAxis),
                    y: {
                        ticks: { color: MUTED, font: { size: 13, weight: '600' } },
                        grid:  { display: false },
                        border:{ color: BORDER }
                    }
                },
                plugins: {
                    legend: { display: false },
                    tooltip: Object.assign({}, tooltipBase, {
                        callbacks: {
                            label: function(c) { return '  ' + c.parsed.x + ' employee' + (c.parsed.x !== 1 ? 's' : ''); }
                        }
                    })
                }
            }
        });
    }

})();
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
